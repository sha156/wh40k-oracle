.env
.env.*
!.env.example
.streamlit/secrets.toml

# Virtual environments
.venv/
venv/

# Python caches
__pycache__/
*.py[cod]
*.pyo

# Build and tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local models and indexes
opt/
local_vector_store/
# 根锚定：只忽略语料 PDF 目录，别误伤 tests/data/ 等测试固定资产
/data/

# wiki_compile 流水线中间产物（产出物 wiki/terms.* 是提交的）
wiki_build/
db_sources/

# db_compile 产出物：wh40k.sqlite 从 db_sources/ CSV 编译生成，不入库
db/
*.sqlite

# Logs and temporary files
*.log
*.err
*.out
temp.pdf
basher.txt

# LLM refined output：整体为生成物、且属规则书衍生内容，不入库。
# 试点《钛帝国十版CODEX》此前已显式提交，仍保持跟踪；其余书目本地保留、不推送。
data_refined/

# QA 基准运行产物（本地保留，不入库）；唯一入库的是 qa_gold.json（题集+权威答案，基准真源）
qa_100_results.json
qa_*_results.json
qa_*_new.json
qa_agent_routed*.json
qa_agent_*.json
qa_classic_*.json
qa_layered_*.json
# 例外：benchmarks/ 下的基线成绩快照是版本冻结档案，入库
!benchmarks/**/qa_agent_*.json

# 黑图书馆抓取数据（10MB+，可由 scripts/fetch_blacklibrary_details.py 重生，不入库）
data_blacklibrary/

# 归档的旧版/冗余数据（本地保留，不入库）
archive/

# OS/editor noise
.DS_Store
Thumbs.db

# Obsidian 本地库配置（wiki/ 作为 vault 打开时生成，纯本地，见 wiki/CLAUDE.md §1）
wiki/.obsidian/

# Local assistant config
.claude/
# 子代理开发流水线（SDD）中间产物
.superpowers/

# BSData 社区库（40MB，英文交叉校验源，本地保留不入库）
db_sources/bsdata/

# Fiddler MCP 本地密钥，禁止提交
.fiddler_key

# from_db 生成的数值漂移 QA 报告（每次重生成，不入库）
wiki/factions/_from_db_drift.md
