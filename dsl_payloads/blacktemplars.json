   "detachment": null,
   "name_en": "Templar Vows",
   "name_zh": "圣堂誓言",
   "status": "partial",
   "effects": [
    {
     "phase": "wound",
     "op": "modify",
     "params": [
      1
     ],
     "condition": [
      "melee_s_lte_t"
     ],
     "source": "圣堂誓言·接受一切挑战（近战最终 S≤T 时致伤+1）"
    }
   ],
   "requires_toggles": [
    "vow_accept_any_challenge"
   ],
   "not_modeled_notes_zh": [
    "誓言为战斗开始时四选一——开关即声明选定「接受一切挑战」；其余三誓言由玩家自行保证未同开",
    "仅黑色圣堂军队适用（BT 为 SM 子阵营无独立阵营行——开关即声明军队为黑色圣堂）",
    "弃绝巫术，讨灭巫师（对灵能者近战 [精准] + 12 寸内冲锋重投并强制接战）：精准=攻击分配域、冲锋=移动域未建模",
    "不容奸邪苟活（撤退后可冲锋 + 跟进/重整移动自由）移动域未建模",
    "捍卫帝皇荣光（目标点持续控制 + 加速后可行动）目标点/任务域未建模",
    "S≤T 判定在引擎最终 S（含 S 特征值改善）处延迟结算——S 改善叠加越过 T 时自动失效（RAW 特征值先改后比）"
   ],
   "provenance": {
